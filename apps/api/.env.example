# Supabase Service Role — Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AES-256 şifreleme anahtarı — 32 byte hex (openssl rand -hex 32 ile üretin)
ENCRYPTION_KEY=your-64-char-hex-key

# WhatsApp Business API — Meta Business Manager
WHATSAPP_ACCESS_TOKEN=your-permanent-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
META_APP_SECRET=your-app-secret

# Gmail OAuth — Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# UYAP — Geliştirme modunda mock kullanır, prodüksiyonda gerçek kimlik bilgileri gerekir
UYAP_MOCK=true

# API
PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
